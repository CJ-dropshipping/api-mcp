# CJ API 环境配置
# 开发环境: http://www.cjdropshipping.offline.pre.com
# 生产环境: https://www.cjdropshipping.com
CJ_API_BASE=http://www.cjdropshipping.offline.pre.com

# 平台标识 (1=MyCJ, 2=OwnCJ, 3=Affiliate)
CJ_PLATFORM=1

# 默认语言
CJ_LANGUAGE=en

# 默认货币
CJ_CURRENCY=USD

# Token 加密密钥 (生产环境请修改)
TOKEN_ENCRYPT_KEY=your-secret-key-here
